<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.linkwisehub.modules.ai.mapper.ConversationMapper">
    <resultMap id="ConversationResultMap" type="com.linkwisehub.modules.ai.entity.Conversation">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="userId" column="user_id"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectAll" resultMap="ConversationResultMap">
        SELECT * FROM lwh_ai_conversation WHERE status = 1 ORDER BY update_time DESC
    </select>

    <select id="selectByUserId" resultMap="ConversationResultMap">
        SELECT * FROM lwh_ai_conversation WHERE user_id = #{userId} AND status = 1 ORDER BY update_time DESC
    </select>

    <select id="selectById" resultMap="ConversationResultMap">
        SELECT * FROM lwh_ai_conversation WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.linkwisehub.modules.ai.entity.Conversation" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO lwh_ai_conversation (title, user_id, status)
        VALUES (#{title}, #{userId}, #{status})
    </insert>

    <update id="updateTitle">
        UPDATE lwh_ai_conversation SET title = #{title} WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE lwh_ai_conversation SET status = #{status} WHERE id = #{id}
    </update>

    <delete id="delete">
        UPDATE lwh_ai_conversation SET status = 0 WHERE id = #{id}
    </delete>
</mapper>
