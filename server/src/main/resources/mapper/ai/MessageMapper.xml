<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.linkwisehub.modules.ai.mapper.MessageMapper">
    <resultMap id="MessageResultMap" type="com.linkwisehub.modules.ai.entity.Message">
        <id property="id" column="id"/>
        <result property="conversationId" column="conversation_id"/>
        <result property="role" column="role"/>
        <result property="content" column="content"/>
        <result property="model" column="model"/>
        <result property="modelName" column="model_name"/>
        <result property="elapsedMs" column="elapsed_ms"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectByConversationId" resultMap="MessageResultMap">
        SELECT * FROM lwh_ai_message WHERE conversation_id = #{conversationId} AND status = 1 ORDER BY create_time ASC, id ASC
    </select>

    <select id="selectById" resultMap="MessageResultMap">
        SELECT * FROM lwh_ai_message WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.linkwisehub.modules.ai.entity.Message" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO lwh_ai_message (conversation_id, role, content, model, model_name, elapsed_ms, status)
        VALUES (#{conversationId}, #{role}, #{content}, #{model}, #{modelName}, #{elapsedMs}, #{status})
    </insert>

    <update id="updateStatus">
        UPDATE lwh_ai_message SET status = #{status} WHERE id = #{id}
    </update>

    <delete id="deleteByConversationId">
        UPDATE lwh_ai_message SET status = 0 WHERE conversation_id = #{conversationId}
    </delete>
</mapper>
